---
import Nav from '../components/Nav.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Footer from '../components/Footer.astro';
import Fab from '../components/Fab.astro';
import { getRooms } from '../data/rooms';
import { getVisibleRetreats } from '../data/retreats';

// Rooms + retreats data are baked into every page so the booking modal
// (injected by site.js on any page) can populate its dropdowns without
// an extra round trip. The lists are small (~7 rows × ~10 fields ≈ 4 KB)
// and change rarely, so this trades a tiny payload bump for instant render.
const rooms = await getRooms();
const roomsForClient = rooms.map((r) => ({
  slug: r.slug,
  name: r.name,
  capacity: r.capacity,
  priceSingle: r.priceSingle,
  priceDouble: r.priceDouble,
}));
const retreatsForClient = (await getVisibleRetreats()).map((r) => ({
  slug: r.slug,
  title: r.title,
  dates: r.dates,
}));

export interface Props {
  title: string;
  description?: string;
  /** Passed through to the Nav for the transparent-over-hero behaviour.
   *  Set on every page that opens with a hero photo (homepage + inner pages). */
  transparent?: boolean;
  /** Highlights the active top-level page in the nav */
  active?: 'retreats' | 'location' | 'how' | 'about' | 'contact' | 'gallery' | null;
  /** Absolute path to the page's hero image (e.g. "/assets/.../main_hero.jpg").
   *  When set, emits a high-priority <link rel="preload"> in <head> so the
   *  browser starts fetching the hero before HTML parsing reaches the <img>.
   *  Eliminates the dark-overlay-then-photo flicker on cold edge cache. */
  heroImage?: string;
}

const {
  title,
  description = 'Small, hosted yoga retreats in Hikkaduwa, Sri Lanka. Eight guests, seven nights, one villa between jungle and sea. Organised from Germany.',
  transparent = false,
  active = null,
  heroImage,
} = Astro.props;
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/assets/logo-mark.png" />
    {heroImage && (
      <link rel="preload" as="image" href={heroImage} fetchpriority="high" />
    )}
    <link rel="stylesheet" href="/css/site.css?v=40" />
  </head>
  <body>
    <Nav transparent={transparent} active={active} />
    <MobileMenu />
    <main>
      <slot />
    </main>
    <Footer />
    <Fab />

    <!-- Rooms + retreats data baked at build time, consumed by the booking modal in site.js. -->
    <script is:inline define:vars={{ roomsForClient, retreatsForClient }}>
      window.THYR_ROOMS = roomsForClient;
      window.THYR_RETREATS = retreatsForClient;
    </script>

    <!-- Shared client scripts. The booking modal's DOM is injected by site.js. -->
    <script src="/js/i18n.js?v=40" is:inline></script>
    <script src="/js/site.js?v=40" is:inline></script>
  </body>
</html>
