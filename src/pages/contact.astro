---
import Base from '../layouts/Base.astro';
---
<Base
  title="Kontakt — Tree House Yoga Retreat"
  description="Say hello. We usually reply the same day, in German or English."
  active="contact"
  transparent={true}
>
  <section class="hero hero--page">
    <img class="hero-bg" src="/assets/images_new/section_hero_images/contact.jpg" alt="Hikkaduwa — schreib uns" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-card">
        <span class="hero-eyebrow" data-i18n="contact.eyebrow">kontakt</span>
        <h1 data-i18n="contact.title">Sag hallo.</h1>
        <p class="sub" data-i18n="contact.body">Meist antworten wir noch am selben Tag. Schreibt ihr uns auf WhatsApp, erreicht ihr uns auf Deutsch; per E-Mail auf Deutsch oder Englisch.</p>
      </div>
    </div>
  </section>

  <section class="section container">
    <div class="contact-grid">
      <form class="form-grid" data-contact novalidate>
        <div>
          <label for="cf-name" data-i18n="contact.f.name">dein name</label>
          <input id="cf-name" name="name" type="text" data-i18n-placeholder="contact.f.name.p" placeholder="Anna Müller" required />
        </div>
        <div>
          <label for="cf-email" data-i18n="contact.f.email">e-mail</label>
          <input id="cf-email" name="email" type="email" data-i18n-placeholder="contact.f.email.p" placeholder="anna@example.de" required />
        </div>
        <div>
          <label for="cf-which" data-i18n="contact.f.which">um welches retreat geht es?</label>
          <input id="cf-which" name="which" type="text" data-i18n-placeholder="contact.f.which.p" placeholder="November 2026 — Dschungel &amp; Meer" />
        </div>
        <div>
          <label for="cf-note" data-i18n="contact.f.note">eine kurze nachricht</label>
          <textarea id="cf-note" name="note" rows="4" data-i18n-placeholder="contact.f.note.p" placeholder="Gibt es etwas, das wir vor eurer Ankunft wissen sollten…"></textarea>
        </div>
        <!-- Honeypot: invisible to humans, bots fill it -->
        <div aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden">
          <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
        </div>
        <div class="form-error" role="alert" aria-live="polite" style="grid-column:1/-1"></div>
        <button type="submit" class="btn btn-primary" data-i18n="contact.send">Senden</button>
        <div class="form-success" hidden style="grid-column:1/-1">
          <h3 data-i18n="contact.success.title">Vielen Dank.</h3>
          <p data-i18n="contact.success.body">Wir haben deine Nachricht erhalten und melden uns bald bei dir.</p>
        </div>
      </form>

      <div class="contact-meta">
        <div>
          <svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 6L2 7"/></svg>
          <div class="label" data-i18n="contact.c.email">e-mail</div>
          <a class="val" href="mailto:hello@treehouseyoga.de">hello@treehouseyoga.de</a>
        </div>
        <div>
          <svg viewBox="0 0 24 24"><path d="M22 16.9v3a2 2 0 01-2.2 2 19.8 19.8 0 01-8.6-3.1 19.5 19.5 0 01-6-6A19.8 19.8 0 012.1 4.2 2 2 0 014.1 2h3a2 2 0 012 1.7c.1.9.3 1.8.6 2.6a2 2 0 01-.4 2.1L8 9.8a16 16 0 006 6l1.4-1.4a2 2 0 012.1-.4c.8.3 1.7.5 2.6.6a2 2 0 011.7 2z"/></svg>
          <div class="label" data-i18n="contact.c.phone">telefon · de</div>
          <a class="val" href="tel:+493012345678">+49 30 1234 5678</a>
        </div>
        <div>
          <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.4A4 4 0 1112.6 8 4 4 0 0116 11.4zM17.5 6.5h.01"/></svg>
          <div class="label" data-i18n="contact.c.ig">instagram</div>
          <a class="val" href="https://instagram.com/treehouseyoga" target="_blank" rel="noopener">@treehouseyoga</a>
        </div>
      </div>
    </div>
  </section>
</Base>
