---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Anzahlung erhalten — Tree House Yoga Retreat"
  description="Vielen Dank — deine Anzahlung ist bei uns angekommen."
>
  <section class="page-head container" style="text-align:center; min-height: 60vh; display: flex; flex-direction: column; justify-content: center;">
    <span class="eyebrow" data-i18n="pay.ok.eyebrow">anzahlung erhalten</span>
    <h1 data-i18n="pay.ok.title">Vielen Dank — wir haben deine Anzahlung erhalten.</h1>
    <p data-i18n="pay.ok.body">Eine Bestätigung per E-Mail ist auf dem Weg. Den Restbetrag bekommst du als Zahlungslink rund 60 Tage vor dem Retreat.</p>
    <p style="margin-top: 32px;">
      <a href="/" class="btn btn-secondary" data-i18n="pay.ok.home">Zur Startseite</a>
    </p>
  </section>
</Base>
