---
import Base from '../layouts/Base.astro';

// Gallery images live in /public/assets. Two sections — yoga retreat (people /
// practice / mat) and beautiful location (jungle / villa setting / sunset).
// Adding/removing images is one line each. The optional `span` property drives
// the masonry layout: 'tall' = doubles row, 'wide' = doubles column.
type Span = 'tall' | 'wide' | null;
interface Img { src: string; span: Span; }

// — Yoga retreat: poses, mats, group portraits.
// Spans assigned by aspect ratio: portrait shots (004, 011, 020) get 'tall',
// the panorama (014) and a couple landscapes get 'wide' for visual rhythm.
const yogaImages: Img[] = [
  { src: '/assets/new_retreat_images/yoga_retreat_001.jpg', span: 'wide' },
  { src: '/assets/new_retreat_images/yoga_retreat_002.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_003.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_004.jpg', span: 'tall' },
  { src: '/assets/new_retreat_images/yoga_retreat_005.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_006.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_007.jpg', span: 'wide' },
  { src: '/assets/new_retreat_images/yoga_retreat_008.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_009.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_010.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_011.jpg', span: 'tall' },
  { src: '/assets/new_retreat_images/yoga_retreat_013.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_014.jpg', span: 'wide' },
  { src: '/assets/new_retreat_images/yoga_retreat_015.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_016.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_017.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_018.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_019.jpg', span: null   },
  { src: '/assets/new_retreat_images/yoga_retreat_020.jpg', span: 'tall' },
  { src: '/assets/new_retreat_images/yoga_retreat_021.jpg', span: null   },
];

// — Beautiful location: villa, treehouse, jungle, lake, surf, golden hour
const locationImages: Img[] = [
  { src: '/assets/die_villa_015.gif',     span: 'tall' },
  { src: '/assets/die_villa_001.gif',     span: 'wide' },
  { src: '/assets/ort_hikkaduwa_01.avif', span: null   },
  { src: '/assets/maduganga_005.jpg',     span: 'tall' },
  { src: '/assets/reefandsurf_001.jpg',   span: 'wide' },
  { src: '/assets/die_villa_012.gif',     span: null   },
  { src: '/assets/maduganga_001.jpg',     span: null   },
  { src: '/assets/reefandsurf_002.jpg',   span: null   },
  { src: '/assets/die_villa_016.gif',     span: 'wide' },
  { src: '/assets/reefandsurf_004.jpg',   span: null   },
  { src: '/assets/die_villa_003.gif',     span: null   },
  { src: '/assets/jungleundlagoon_001.gif', span: null },
];

const classFor = (s: Span) => s === 'tall' ? 'g-item g-tall' : s === 'wide' ? 'g-item g-wide' : 'g-item';
---
<Base
  title="Galerie — Tree House Yoga Retreat"
  description="Glimpses from Hikkaduwa — yoga, the villa, the jungle, the mornings."
  active="gallery"
  transparent={true}
  heroImage="/assets/images_new/section_hero_images/gallery.jpg"
>
  <section class="hero hero--page">
    <img class="hero-bg" src="/assets/images_new/section_hero_images/gallery.jpg" alt="Eindrücke aus Hikkaduwa" fetchpriority="high" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-card">
        <span class="hero-eyebrow" data-i18n="gallery.eyebrow">galerie</span>
        <h1 data-i18n="gallery.title">Eindrücke aus Hikkaduwa.</h1>
        <p class="sub" data-i18n="gallery.body">Die Praxis und der Ort. Ein kleiner Spaziergang durch die Woche.</p>
      </div>
    </div>
  </section>

  <!-- ─── Section 1 · Yoga retreat ─── -->
  <section class="section container" style="padding-top:0">
    <div class="section-head left">
      <span class="eyebrow" data-i18n="gallery.yoga.eyebrow">yoga retreat</span>
      <h2 data-i18n="gallery.yoga.title">Praxis und Stille.</h2>
      <p data-i18n="gallery.yoga.body">Asanas, Atem und gemeinsame Stunden auf der Matte — drinnen wie draußen.</p>
    </div>

    <div class="gallery-grid">
      {yogaImages.map((img) => (
        <figure class={classFor(img.span)}>
          <img src={img.src} alt="" loading="lazy" />
        </figure>
      ))}
    </div>
  </section>

  <!-- ─── Section 2 · Beautiful location ─── -->
  <section class="section container">
    <div class="section-head left">
      <span class="eyebrow" data-i18n="gallery.loc.eyebrow">der ort</span>
      <h2 data-i18n="gallery.loc.title">Zwischen Dschungel und Meer.</h2>
      <p data-i18n="gallery.loc.body">Die Villa, die Lagune, das Licht am späten Nachmittag — der Ort, an dem die Woche stattfindet.</p>
    </div>

    <div class="gallery-grid">
      {locationImages.map((img) => (
        <figure class={classFor(img.span)}>
          <img src={img.src} alt="" loading="lazy" />
        </figure>
      ))}
    </div>
  </section>

  <!-- Lightbox overlay -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-hidden="true">
    <button class="lb-close" aria-label="Close">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
    <button class="lb-prev" aria-label="Previous">
      <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <img class="lb-img" alt="" />
    <button class="lb-next" aria-label="Next">
      <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
    </button>
    <div class="lb-count" aria-live="polite"></div>
  </div>

  <script is:inline>
    (function(){
      // Walks every gallery section on the page so the lightbox cycles through
      // both yoga and location images in document order.
      var items = Array.prototype.slice.call(document.querySelectorAll('.gallery-grid .g-item img'));
      var lb = document.getElementById('lightbox');
      if (!lb) return;
      var lbImg = lb.querySelector('.lb-img');
      var lbCount = lb.querySelector('.lb-count');
      var idx = 0;
      function show(i){
        idx = (i + items.length) % items.length;
        lbImg.src = items[idx].src;
        lbCount.textContent = (idx+1) + ' / ' + items.length;
      }
      function open(i){ show(i); lb.classList.add('is-open'); lb.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
      function close(){ lb.classList.remove('is-open'); lb.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
      items.forEach(function(img, i){
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', function(){ open(i); });
      });
      lb.querySelector('.lb-close').addEventListener('click', close);
      lb.querySelector('.lb-prev').addEventListener('click', function(){ show(idx-1); });
      lb.querySelector('.lb-next').addEventListener('click', function(){ show(idx+1); });
      lb.addEventListener('click', function(e){ if(e.target===lb) close(); });
      document.addEventListener('keydown', function(e){
        if(!lb.classList.contains('is-open')) return;
        if(e.key==='Escape') close();
        else if(e.key==='ArrowLeft') show(idx-1);
        else if(e.key==='ArrowRight') show(idx+1);
      });
    })();
  </script>
</Base>
