---
import type { Retreat } from '../data/retreats';

interface Props {
  retreat: Retreat;
}
const { retreat } = Astro.props;

// Filter attributes — read by initRetreatFilters() in site.js.
//   data-month   YYYY-MM derived from startDate (empty if not set)
//   data-tags    space-separated tag slugs
//   data-soldout 'true' | 'false'
const filterMonth = retreat.startDate ? retreat.startDate.slice(0, 7) : '';
const filterTags = retreat.tags.join(' ');
const filterSoldOut = retreat.soldOut ? 'true' : 'false';
---
<a
  class="retreat-card"
  href={`/retreats/${retreat.slug}.html`}
  data-month={filterMonth}
  data-tags={filterTags}
  data-soldout={filterSoldOut}
>
  <div class="r-img">
    {retreat.spots.de && (
      <span
        class="r-badge"
        data-i18n-de={retreat.spots.de}
        data-i18n-en={retreat.spots.en}
      >{retreat.spots.de}</span>
    )}
    <img src={retreat.cardImage} alt="" />
  </div>

  <div class="r-body">
    <div class="r-info">
      <span
        class="r-eyebrow"
        data-i18n-de={retreat.prefix.de}
        data-i18n-en={retreat.prefix.en}
      >{retreat.prefix.de}</span>
      <h3
        data-i18n-de={retreat.title.de}
        data-i18n-en={retreat.title.en}
      >{retreat.title.de}</h3>

      <ul class="r-meta">
        <li>
          <svg class="r-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="17" rx="2"></rect>
            <path d="M3 9h18M8 2v4M16 2v4"></path>
          </svg>
          <span data-i18n-de={retreat.dates.de} data-i18n-en={retreat.dates.en}>{retreat.dates.de}</span>
        </li>
        <li>
          <svg class="r-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s7-7.5 7-13a7 7 0 1 0-14 0c0 5.5 7 13 7 13z"></path>
            <circle cx="12" cy="9" r="2.5"></circle>
          </svg>
          <span>Hikkaduwa, Sri Lanka</span>
        </li>
        <li>
          <svg class="r-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13A4 4 0 0 1 16 11"></path>
          </svg>
          <span><b>{retreat.guests}</b> <span data-i18n="r.guests">Gäste</span></span>
        </li>
      </ul>
    </div>

    <div class="r-aside">
      {retreat.price && (
        <div class="r-price">
          <small class="r-from" data-i18n="r.from">ab</small>
          <span class="r-amount">{retreat.price}</span>
          <small class="r-per" data-i18n="r.perPerson">pro Person</small>
        </div>
      )}
      <span class="r-cta" data-i18n="r.more">Mehr erfahren →</span>
    </div>
  </div>
</a>
